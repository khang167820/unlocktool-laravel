<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect test.unlocktool.us → unlocktool.us (301 permanent)
    RewriteCond %{HTTP_HOST} ^test\.unlocktool\.us$ [NC]
    RewriteRule ^(.*)$ https://unlocktool.us/$1 [R=301,L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} ^unlocktool\.us$ [NC]
    RewriteRule ^(.*)$ https://unlocktool.us/$1 [R=301,L]

    # Force non-www
    RewriteCond %{HTTP_HOST} ^www\.unlocktool\.us$ [NC]
    RewriteRule ^(.*)$ https://unlocktool.us/$1 [R=301,L]

    # If the request is for a real file or directory in public/, serve it
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Security: Block access to sensitive files
<FilesMatch "\.(env|gitignore|gitattributes|md|lock|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to artisan and composer files
<FilesMatch "^(artisan|composer\.(json|lock))$">
    Order allow,deny
    Deny from all
</FilesMatch>
